{
  "name": "linkhub",
  "description": "Smart bookmark manager",
  "author": "LinkHub",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "test": "vitest run",
    "dev:electron": "concurrently \"npm run dev\" \"node scripts/electron-dev-setup.mjs && wait-on file:.server-port && tsup && node scripts/electron-dev.mjs\"",
    "build": "vite build && tsup",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron release",
    "lint": "tsc --noEmit",
    "start": "tsx server.ts"
  },
  "build": {
    "appId": "com.linkhub.app",
    "productName": "LinkHub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "public/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "artifactName": "LinkHub-Portable-${version}-Win64.exe"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.4.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "openai": "^6.32.0",
    "react-arborist": "^3.5.0",
    "react-dnd-touch-backend": "^14.1.1",
    "tldts": "^7.0.25",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.0",
    "@types/mozilla-readability": "^0.2.1",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eruda": "^3.4.3",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  }
}
